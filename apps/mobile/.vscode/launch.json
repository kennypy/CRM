{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NexCRM (debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_URL=http://10.0.2.2:4000",
        "--dart-define=AUTH_URL=http://10.0.2.2:4001"
      ]
    },
    {
      "name": "NexCRM (profile)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "args": [
        "--dart-define=API_URL=http://10.0.2.2:4000",
        "--dart-define=AUTH_URL=http://10.0.2.2:4001"
      ]
    },
    {
      "name": "NexCRM (release)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "args": [
        "--dart-define=API_URL=https://api.nexcrm.com",
        "--dart-define=AUTH_URL=https://auth.nexcrm.com"
      ]
    }
  ]
}
