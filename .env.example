# ============================================================
# NexCRM — Environment Variables Reference
# Copy to .env and fill in your values. Never commit .env.
#
# Generating secrets (run in terminal):
#   JWT_SECRET / REFRESH_TOKEN_SECRET:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   OAUTH_ENCRYPTION_KEY (must be exactly 64 hex chars = 32 bytes):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   REDIS_PASSWORD:
#     node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
#
# Never use the placeholder values in production.
# ============================================================

# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# Marks session cookies `Secure`. Leave "false" for plain-HTTP LAN/self-hosted
# deploys (browsers drop Secure cookies over http:// and login silently fails).
# Set to "true" when the web app is served over HTTPS.
COOKIE_SECURE=false
# Set to "true" when running behind a reverse proxy (nginx, ALB, Cloud Run).
# Allows the gateway to read the real client IP from X-Forwarded-For.
TRUST_PROXY=true

# --- Internal Service URLs (for local dev; use service names in Docker) ---
AUTH_SERVICE_URL=http://localhost:4001
AUTH_PORT=4001
GRAPH_CORE_URL=http://localhost:4002
GRAPH_CORE_PORT=4002
OUTREACH_URL=http://localhost:4003
OUTREACH_PORT=4003
AI_ENGINE_URL=http://localhost:5001
INGESTION_URL=http://localhost:5002

# --- Internal Service Token ---
# Shared secret for gateway → service authentication.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. In dev, set ALLOW_MISSING_SERVICE_TOKEN=true to skip.
INTERNAL_SERVICE_SECRET=replace-with-openssl-rand-hex-32
# Set during secret rotation; leave empty normally.
INTERNAL_SERVICE_SECRET_NEXT=
# Dev only — allows services to start without a service token. Remove in production.
ALLOW_MISSING_SERVICE_TOKEN=true

# --- Database (PostgreSQL + Apache AGE graph extension) ---
DATABASE_URL=postgresql://nexcrm:nexcrm_dev@localhost:5432/nexcrm
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Redis (cache + event streams) ---
# REDIS_PASSWORD must match the --requirepass value in docker-compose.yml
REDIS_PASSWORD=nexcrm_redis_dev_password
REDIS_URL=redis://:nexcrm_redis_dev_password@localhost:6379

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_256bit_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_different_256bit_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# --- OAuth Token Encryption (AES-256-GCM) ---
# Encrypts Google/Microsoft OAuth tokens at rest in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Required — auth service will not start without it.
OAUTH_ENCRYPTION_KEY=replace_with_64char_hex_string

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Okta enterprise SSO (OIDC) ---
# Set all three to enable the "Sign in with Okta" button on the login page.
# In the Okta app (type: OIDC Web Application), set the sign-in redirect URI to
#   ${APP_URL}/api/auth/sso/okta/callback
# OKTA_ISSUER: the issuer URL. Org auth server = https://YOUR-ORG.okta.com ;
# custom auth server = https://YOUR-ORG.okta.com/oauth2/default
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Slack webhook signature verification secret (from Slack App > Basic Information > Signing Secret)
# Different from SLACK_CLIENT_SECRET. Required for /webhooks/slack to accept events.
SLACK_SIGNING_SECRET=

# --- AI / LLM ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=8192
# Confidence threshold below which AI writes go to review queue
AI_CONFIDENCE_THRESHOLD=0.75

# --- Vector Store (pgvector — same Postgres instance) ---
VECTOR_DIMENSIONS=1536

# --- File Storage (S3-compatible) ---
# Change minioadmin credentials in production — these are the MinIO root credentials.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nexcrm-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Typesense ---
TYPESENSE_API_KEY=nexcrm-typesense-dev-key

# --- Email Ingestion ---
GMAIL_OAUTH_REDIRECT=http://localhost:4000/integrations/gmail/callback
OUTLOOK_OAUTH_REDIRECT=http://localhost:4000/integrations/outlook/callback

# --- Outreach / Dialer (Twilio) ---
# Stored encrypted in DB — configure via Settings > Dialer in the UI.
# These vars are for reference only; the outreach service reads from dialer_configs table.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TWIML_APP_SID=

# --- AI Outreach Provider ---
# Default: uses ANTHROPIC_API_KEY above.
# Override per-tenant via tenants.settings.ai_outreach in the DB, or Settings > AI Provider.
# Supports any OpenAI-compatible endpoint (Ollama, OpenAI, LM Studio etc.)
# AI_OUTREACH_PROVIDER=openai_compat
# AI_OUTREACH_BASE_URL=http://localhost:11434/v1
# AI_OUTREACH_MODEL=llama3.2

# --- Zoom / Transcripts ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# --- Vintage.br inbound support webhook ---
# Shared secret used to verify HMAC-SHA256 signatures on /webhooks/vintage.
# Must match SUPPORT_CRM_WEBHOOK_SECRET on the Vintage.br side. Required in
# production — the gateway refuses to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VINTAGE_WEBHOOK_SECRET=

# --- Vintage.br outbound partner API ---
# Base URL for the partner endpoints the CRM calls when agents reply /
# resolve / assign a ticket. Without these, the outbound dispatcher stays
# offline and agent replies pile up in 'pending' until env is set.
# Required in production.
VINTAGE_API_URL=https://api.vintage.br
# Shared partner key sent as X-Partner-Key on every outbound request.
# Rotate in lockstep with Vintage.
CRM_PARTNER_KEY=
# Webhook URL paged when a Vintage outbound job dead-letters (auth error,
# permanent 4xx, or reconcile exhaustion). Any HTTP sink works — Slack
# incoming webhooks, PagerDuty Events API, Opsgenie, Mattermost. Unset in
# dev turns paging into a log-once warning.
SUPPORT_DEAD_LETTER_WEBHOOK_URL=

# --- Support ticket attachments (public surface) ---
# Base URL for permanent public-read access to files uploaded via
# /api/v1/support-tickets/attachments. The route appends the object key to
# this base and hands the resulting URL to the reply composer; Vintage
# stores the URL as a string and never re-signs, so this MUST resolve
# forever or customers see broken attachment links.
#
# Valid configurations:
#   - A public-read S3 bucket origin, e.g. https://nexcrm-files.s3.us-east-1.amazonaws.com
#   - A CloudFront distribution fronting the bucket (recommended)
#   - A Cloudflare R2 custom domain
#   - For MinIO / dev: http://localhost:9000/nexcrm-files (bucket public-read)
#
# Required — attachment uploads 503 until this is set.
SUPPORT_ATTACHMENTS_PUBLIC_BASE_URL=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=debug
# Grafana admin password. Anonymous access is disabled in docker-compose.yml,
# so this is the only way in. The compose :- fallback is "admin" for local dev,
# but you MUST set a strong value here for any shared/staging/production stack.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
GRAFANA_ADMIN_PASSWORD=change-me-in-shared-environments

# --- Sentry (error tracking) ---
# Get DSN from sentry.io > Project > Settings > SDK Setup
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Set in CI to upload source maps (requires org/project tokens from Sentry)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Set to the git SHA or tag for release tracking
SENTRY_RELEASE=

# --- Tenant / Multi-tenancy ---
DEFAULT_TENANT_ID=dev-tenant-001

# --- Demo / Read-only tour ---
# Password for the read-only demo visitor account (visitor@demo.nexcrm.io).
# Read server-side by apps/web/src/app/api/demo/session/route.ts. Must match the
# demo seed data. The dev default is "DemoVisitor@nexcrm1"; override per environment.
DEMO_USER_PASSWORD=DemoVisitor@nexcrm1

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
# Stripe Customer Portal — configure at dashboard.stripe.com/test/settings/billing/portal
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings/billing

# --- Transactional Email (Resend) ---
# Get API key at resend.com — add and verify your sending domain first
RESEND_API_KEY=
EMAIL_FROM=NexCRM <noreply@nexcrm.io>

# --- Product Analytics (PostHog) ---
# Get from app.posthog.com > Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Database Connection Pooling (PgBouncer) ---
# In production: point DATABASE_URL at PgBouncer (port 5433), not Postgres directly.
# DATABASE_URL=postgresql://nexcrm:nexcrm_dev@localhost:5433/nexcrm
# Separate read-replica for reporting queries (falls back to DATABASE_URL if unset)
DATABASE_URL_REPLICA=

# ============================================================
# Security hardening (added by the red-team remediation)
# ============================================================

# --- SSRF egress guards ---
# Outbound customer webhooks and the per-tenant AI provider base_url are blocked
# from reaching loopback / private / link-local / cloud-metadata addresses.
# Set to "true" ONLY for intentional self-hosted/dev targets (e.g. local Ollama).
WEBHOOKS_ALLOW_PRIVATE_HOST=false
OUTREACH_ALLOW_PRIVATE_AI_HOST=false

# --- Support tickets (Vintage.br global queue) ---
# The support queue has no per-tenant column, so access is restricted to the
# operator's support staff: the tenant whose id matches this value. REQUIRED in
# production — the support-tickets API returns 503 until it is set.
SUPPORT_OPERATOR_TENANT_ID=

# --- Auth: access-token revocation ---
# TTL (seconds) for the per-user logout/reset deny-list marker; should match the
# access-token lifetime (JWT_EXPIRES_IN).
ACCESS_TOKEN_TTL_SECONDS=900

# --- Inbound email/calendar webhook authenticity (ingestion) ---
# Expected audience for the Google Pub/Sub push OIDC JWT on the Gmail webhook.
# Set to the push endpoint URL configured in the Pub/Sub subscription.
GMAIL_PUBSUB_AUDIENCE=
# Per-tenant graph node auto-creation rate limit (anti-spoofing / anti-flood).
ENTITY_AUTO_CREATE_LIMIT=200
ENTITY_AUTO_CREATE_WINDOW_SECONDS=3600

# --- AI engine: unattended-write policy ---
# Untrusted (inbound-email-sourced) extractions ALWAYS go to the review queue.
# Auto-write to the graph is disabled by default; enable only for trusted
# internal sources after review, and only with an explicit allowlist.
AI_ALLOW_AUTO_WRITE=false
AI_TRUSTED_SOURCES=internal

# --- Outreach / Twilio ---
# Dedicated Twilio API Key used to sign Voice AccessTokens (do NOT use the
# account auth token). REQUIRED in production to mint dialer tokens; can also be
# set per-tenant in the encrypted dialer config.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Public origin Twilio signs status callbacks against, used to reconstruct the
# signed URL when no forwarded host header is present (falls back to APP_URL).
TWILIO_WEBHOOK_PUBLIC_URL=
# HMAC secret for one-click unsubscribe links (falls back to JWT_SECRET if unset).
UNSUBSCRIBE_SIGNING_SECRET=
