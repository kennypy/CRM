# NexCRM Demo Instance — Environment Variables
# Copy this to .env and fill in production values
#
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NODE_ENV=production
APP_URL=https://demo.nexcrm.io
API_URL=https://demo.nexcrm.io/api

# --- Database ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://nexcrm:CHANGE_ME_STRONG_PASSWORD@postgres:5432/nexcrm

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- Authentication ---
JWT_SECRET=CHANGE_ME_256BIT_HEX_SECRET
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_DIFFERENT_256BIT_HEX_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d

# --- OAuth Encryption (required by auth service) ---
OAUTH_ENCRYPTION_KEY=CHANGE_ME_64CHAR_HEX_STRING_FOR_AES256

# --- Internal Service Token ---
INTERNAL_SERVICE_SECRET=CHANGE_ME_SERVICE_SECRET
TRUST_PROXY=true

# --- Internal Service URLs (Docker network names) ---
AUTH_SERVICE_URL=http://auth:4001
GRAPH_CORE_URL=http://graph-core:4002
OUTREACH_URL=http://outreach:4003
AI_ENGINE_URL=http://ai-engine:5001

# --- Typesense ---
TYPESENSE_API_KEY=CHANGE_ME_TYPESENSE_KEY

# --- Email (Resend) ---
# Optional for demo — emails will be logged to console if not set
RESEND_API_KEY=
EMAIL_FROM=NexCRM <noreply@nexcrm.io>

# --- Stripe (optional for demo) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=https://demo.nexcrm.io/settings/billing

# --- AI (optional — demo works without it) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=8192
AI_CONFIDENCE_THRESHOLD=0.75

# --- Observability (disabled for demo) ---
LOG_LEVEL=info
